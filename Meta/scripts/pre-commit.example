#!/bin/bash
#
# Git pre-commitフックの例
# ステージされたMarkdownファイルのfrontmatter `updated_at` を自動更新します。
#
# 使い方:
#   cp Meta/scripts/pre-commit.example .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#

set -euo pipefail

# 変更（追加/修正/コピー）されたステージ済みMarkdownファイルを取得
STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$' || true)

if [ -z "${STAGED_MD_FILES}" ]; then
  exit 0
fi

SCRIPT_PATH="Meta/scripts/update_frontmatter_on_edit.py"

for file in ${STAGED_MD_FILES}; do
  if [ -f "${file}" ]; then
    python3 "${SCRIPT_PATH}" "${file}"
    git add "${file}"
  fi
done

exit 0

